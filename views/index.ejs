<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Game Controller</title>
    <script src="/socket.io/socket.io.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    <style>
      body {
        font-family: Arial, sans-serif;
        background-color: #222;
        color: #fff;
        text-align: center;
        margin: 0;
        padding: 0;
        display: flex;
        justify-content: center;
        align-items: center;
        min-height: 100vh;
        overflow: hidden;
      }
      .container {
        width: 90%;
        max-width: 600px;
        background: #333;
        padding: 30px;
        border-radius: 15px;
        box-shadow: 0 8px 20px rgba(0, 0, 0, 0.7);
        position: relative;
      }
      #interaction-blocker {
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        background-color: rgba(0, 0, 0, 0.5);
        z-index: 1000;
        border-radius: 15px;
        display: none;
        justify-content: center;
        align-items: center;
        cursor: not-allowed;
        backdrop-filter: blur(2px);
      }
      .loading-text {
        font-size: 20px;
        font-weight: bold;
        color: #ffeb3b;
        animation: pulse 1s infinite;
      }
      @keyframes pulse {
        0% {
          opacity: 1;
        }
        50% {
          opacity: 0.5;
        }
        100% {
          opacity: 1;
        }
      }

      button {
        background-color: #4caf50;
        color: white;
        border: none;
        padding: 15px 32px;
        font-size: 16px;
        margin: 10px 0;
        cursor: pointer;
        width: 100%;
        border-radius: 8px;
        transition:
          transform 0.1s,
          background-color 0.2s,
          opacity 0.2s;
      }
      button:active:not(:disabled) {
        background-color: #45a049;
        transform: scale(0.98);
      }
      button:disabled {
        background-color: #888 !important;
        color: #ccc;
        cursor: not-allowed;
        opacity: 0.6;
      }

      .btn-fullscreen {
        position: fixed;
        top: 15px;
        right: 15px;
        width: auto;
        padding: 10px 15px;
        background-color: rgba(85, 85, 85, 0.4);
        font-size: 14px;
        border-radius: 8px;
        margin: 0;
        z-index: 9999;
        backdrop-filter: blur(5px);
      }
      .btn-reset {
        position: fixed;
        bottom: 15px;
        right: 15px;
        width: auto;
        padding: 10px 20px;
        background-color: #f44336;
        color: white;
        font-size: 16px;
        font-weight: bold;
        border-radius: 8px;
        margin: 0;
        z-index: 9999;
        box-shadow: 0 4px 10px rgba(0, 0, 0, 0.5);
      }

      input[type="text"] {
        width: calc(100% - 30px);
        padding: 15px;
        margin: 15px 0;
        font-size: 16px;
        border-radius: 8px;
        border: none;
        text-align: center;
      }
      input:focus {
        outline: 2px solid #4caf50;
      }

      .panel {
        display: none;
      }
      .panel.active {
        display: block;
        animation: fadeIn 0.3s ease-in-out;
      }
      @keyframes fadeIn {
        from {
          opacity: 0;
          transform: translateY(10px);
        }
        to {
          opacity: 1;
          transform: translateY(0);
        }
      }

      .grid-container {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 8px;
        margin-top: 20px;
      }
      .grid-container div {
        height: 100px;
        font-size: 40px;
        font-weight: bold;
        margin: 0;
        background-color: #555;
        border-radius: 12px;
        display: flex;
        justify-content: center;
        align-items: center;
      }

      #connection-status {
        position: fixed;
        top: 15px;
        left: 15px;
        padding: 10px 15px;
        border-radius: 8px;
        background-color: rgba(85, 85, 85, 0.4);
        font-size: 14px;
        font-weight: bold;
        z-index: 9999;
        backdrop-filter: blur(5px);
        transition: color 0.3s ease;
      }
      .status-online {
        color: #4caf50;
      }
      .status-offline {
        color: #f44336;
      }

      .btn-upload {
        background-color: #9c27b0;
        margin-top: 20px;
      }
    </style>
  </head>
  <body>
    <button class="btn-fullscreen" onclick="toggleFullScreen()">⛶</button>
    <div id="connection-status" class="status-offline">🔴 Game Offline</div>
    <button class="btn-reset" onclick="confirmReset()">🔄 Reset</button>

    <div class="container">
      <div id="interaction-blocker">
        <div class="loading-text">Tunggu Sebentar...</div>
      </div>

      <h2>Game Controller</h2>
      <hr style="border: 1px solid #555; margin-bottom: 20px" />

      <div id="panel-start" class="panel active">
        <button id="btnStart" onclick="onStartGame()">▶️ Start Game</button>
        <button
          id="btnLeaderboard"
          onclick="onShowLeaderboard()"
          style="background-color: #ff9800"
        >
          📃 Show Leaderboard
        </button>
        <button
          id="btnLoop"
          onclick="onToggleLoop()"
          style="background-color: #2196f3"
        >
          🎬 Switch to Loop (OFF)
        </button>

        <hr style="border: 1px dashed #555; margin: 20px 0" />
        <button id="btnUpload" class="btn-upload" onclick="openUploadModal()">
          📤 Upload New Loop
        </button>
      </div>

      <div id="panel-mode" class="panel">
        <h3>Pilih Mode Bermain</h3>
        <button onclick="onSelectMode(0)" style="background-color: #2196f3">
          👤 1 Player (vs Bot)
        </button>
        <button onclick="onSelectMode(1)" style="background-color: #ff9800">
          👥 2 Players
        </button>
      </div>
      <div id="panel-name" class="panel">
        <h3 id="nameTitle">Input Player 1 Name</h3>
        <input
          type="text"
          id="playerNameInput"
          placeholder="Ketik nama di sini..."
          autocomplete="off"
          maxlength="6"
          oninput="this.value = this.value.toUpperCase()"
        />
        <button onclick="onSubmitName()">Submit Nama</button>
      </div>
      <div id="panel-countdown" class="panel">
        <h3>Game Dimulai Dalam...</h3>
        <h1
          id="countdownText"
          style="font-size: 80px; color: #ffeb3b; margin: 20px 0"
        >
          3
        </h1>
      </div>
      <div id="panel-game" class="panel">
        <h3 id="turnIndicator" style="color: #ffeb3b">Menunggu Giliran...</h3>
        <div id="miniGrid" class="grid-container">
          <div id="cell-0"></div>
          <div id="cell-1"></div>
          <div id="cell-2"></div>
          <div id="cell-3"></div>
          <div id="cell-4"></div>
          <div id="cell-5"></div>
          <div id="cell-6"></div>
          <div id="cell-7"></div>
          <div id="cell-8"></div>
        </div>
      </div>
    </div>

    <script>
      const socket = io();
      let isGameConnected = false;
      let currentMode = 0;
      let nameStage = 1;
      let movesX = [];
      let movesO = [];
      let isAdsRunning = false;

      socket.on("connect", () => {
        console.log("Terhubung ke Server!");
      });

      socket.on("gameStateChanged", (isConnected) => {
        const statusEl = document.getElementById("connection-status");
        isGameConnected = isConnected;
        if (isConnected) {
          statusEl.innerText = "🟢 Game Online";
          statusEl.className = "status-online";
        } else {
          statusEl.innerText = "🔴 Game Offline";
          statusEl.className = "status-offline";
          resetTabletUI();
        }
      });

      socket.on("syncLoopState", (isLooping) => {
        isAdsRunning = isLooping;
        const btnLoop = document.getElementById("btnLoop");
        const btnStart = document.getElementById("btnStart");
        const btnLeaderboard = document.getElementById("btnLeaderboard");

        if (isAdsRunning) {
          btnLoop.innerText = "⏹️ Switch to Menu";
          btnLoop.style.backgroundColor = "#f44336";
          btnStart.disabled = true;
          btnLeaderboard.disabled = true;
        } else {
          btnLoop.innerText = "🎬 Switch to Loop";
          btnLoop.style.backgroundColor = "#2196f3";
          btnStart.disabled = false;
          btnLeaderboard.disabled = false;
        }
      });

      function onToggleLoop() {
        if (!checkConnection()) return;
        socket.emit("toggleLoop");
      }

      function openUploadModal() {
        if (isAdsRunning) {
          Swal.fire({
            icon: "warning",
            title: "Iklan Sedang Berjalan",
            text: "Matikan mode iklan terlebih dahulu sebelum mengunggah video baru.",
            background: "#333",
            color: "#fff",
          });
          return;
        }

        Swal.fire({
          title: "Upload Video Iklan",
          html: `<input type="file" id="videoFileInput" accept="video/mp4" style="width: 80%; background: #222; color: white; padding: 10px; border-radius: 5px;">`,
          showCancelButton: true,
          confirmButtonText: "Upload",
          showLoaderOnConfirm: true,
          allowOutsideClick: () => !Swal.isLoading(),
          background: "#333",
          color: "#fff",
          preConfirm: () => {
            const fileInput = document.getElementById("videoFileInput");
            if (!fileInput.files.length) {
              Swal.showValidationMessage(
                "Silakan pilih file video MP4 terlebih dahulu",
              );
              return false;
            }

            const formData = new FormData();
            formData.append("videoFile", fileInput.files[0]);

            return fetch("/upload", {
              method: "POST",
              body: formData,
            })
              .then((response) => {
                if (!response.ok) {
                  throw new Error(response.statusText);
                }
                return response.json();
              })
              .catch((error) => {
                Swal.showValidationMessage(`Gagal mengunggah: ${error}`);
              });
          },
        }).then((result) => {
          if (result.isConfirmed) {
            Swal.fire({
              icon: "success",
              title: "Berhasil!",
              text: "Video telah disimpan di folder server.",
              background: "#333",
              color: "#fff",
            });
          }
        });
      }

      function showPanel(panelId) {
        const panels = document.querySelectorAll(".panel");
        panels.forEach((p) => p.classList.remove("active"));
        document.getElementById(panelId).classList.add("active");
      }

      socket.on("syncInteractable", (isInteractable) => {
        const blocker = document.getElementById("interaction-blocker");
        if (isInteractable) {
          blocker.style.display = "none";
        } else {
          blocker.style.display = "flex";
        }
      });

      function checkConnection() {
        if (!isGameConnected) {
          Swal.fire({
            icon: "error",
            title: "Koneksi Terputus!",
            text: "Game Unity belum terhubung ke Server.",
            background: "#333",
            color: "#fff",
            confirmButtonColor: "#f44336",
            confirmButtonText: "Tutup",
          });
          return false;
        }
        return true;
      }

      function onStartGame() {
        if (checkConnection()) {
          socket.emit("startGame");
          showPanel("panel-mode");
        }
      }

      function onShowLeaderboard() {
        if (checkConnection()) socket.emit("showLeaderboard");
      }

      function onSelectMode(mode) {
        if (!checkConnection()) return;
        currentMode = mode;
        socket.emit("selectMode", mode);
        nameStage = 1;
        document.getElementById("nameTitle").innerText = "Input Player 1 Name";
        document.getElementById("playerNameInput").value = "";
        showPanel("panel-name");
      }

      function onSubmitName() {
        if (!checkConnection()) return;
        const nameInput = document.getElementById("playerNameInput");
        const nameValue = nameInput.value.trim();

        if (nameValue === "") {
          Swal.fire({
            icon: "warning",
            title: "Tunggu dulu!",
            text: "Nama tidak boleh kosong!",
            background: "#333",
            color: "#fff",
            confirmButtonColor: "#ff9800",
          });
          return;
        }

        socket.emit("submitName", { player: nameStage, name: nameValue });

        if (currentMode === 1 && nameStage === 1) {
          nameStage = 2;
          document.getElementById("nameTitle").innerText =
            "Input Player 2 Name";
          nameInput.value = "";
          nameInput.focus();
        } else {
          setTimeout(() => {
            startCountdown();
          }, 2000);
        }
      }

      function startCountdown() {
        showPanel("panel-countdown");
        let count = 3;
        const countdownElement = document.getElementById("countdownText");
        countdownElement.innerText = count;

        const interval = setInterval(() => {
          count--;
          if (count > 0) {
            countdownElement.innerText = count;
          } else {
            clearInterval(interval);
            showPanel("panel-game");
          }
        }, 1000);
      }

      function confirmReset() {
        if (!checkConnection()) return;
        Swal.fire({
          title: "Reset Permainan?",
          text: "Semua progres akan hilang.",
          icon: "warning",
          showCancelButton: true,
          background: "#333",
          color: "#fff",
          confirmButtonColor: "#f44336",
          cancelButtonColor: "#555",
          confirmButtonText: "Ya, Reset!",
          cancelButtonText: "Batal",
        }).then((result) => {
          if (result.isConfirmed) {
            socket.emit("resetGame");
            resetTabletUI();
            document.getElementById("interaction-blocker").style.display =
              "none";
          }
        });
      }

      socket.on("syncGrid", (data) => {
        const cell = document.getElementById(`cell-${data.index}`);
        if (!cell) return;
        if (data.side === "") {
          cell.innerText = "";
          cell.style.backgroundColor = "#555";
          cell.style.opacity = "1";
          movesX = movesX.filter((i) => i !== data.index);
          movesO = movesO.filter((i) => i !== data.index);
          updateFadingVisuals();
          return;
        }
        cell.innerText = data.side;
        cell.style.backgroundColor = data.side === "X" ? "#8BC34A" : "#9C27B0";
        cell.style.opacity = "1";
        if (data.side === "X") {
          movesX.push(data.index);
        } else if (data.side === "O") {
          movesO.push(data.index);
        }
        updateFadingVisuals();
      });

      function updateFadingVisuals() {
        for (let i = 0; i < 9; i++) {
          document.getElementById(`cell-${i}`).style.opacity = "1";
        }
        if (movesX.length === 3) {
          document.getElementById(`cell-${movesX[0]}`).style.opacity = "0.3";
        }
        if (movesO.length === 3) {
          document.getElementById(`cell-${movesO[0]}`).style.opacity = "0.3";
        }
      }

      socket.on("syncTurn", (data) => {
        document.getElementById("turnIndicator").innerText =
          "Giliran: " + data.playerName;
      });
      socket.on("syncGameOver", (data) => {
        Swal.fire({
          title: "Game Over!",
          text: data.winner,
          icon: "success",
          background: "#333",
          color: "#fff",
          confirmButtonColor: "#4caf50",
          confirmButtonText: "Selesai",
          allowOutsideClick: false,
        });
      });
      socket.on("backtohome", () => {
        resetTabletUI();
      });
      socket.on("gameOfflineError", () => {
        Swal.fire({
          icon: "error",
          title: "Koneksi Terputus!",
          text: "Sudah ada tablet yang mengontrol game ini.",
          background: "#333",
          color: "#fff",
          confirmButtonColor: "#f44336",
          confirmButtonText: "Tutup",
        });
      });

      function resetTabletUI() {
        movesX = [];
        movesO = [];
        for (let i = 0; i < 9; i++) {
          let cell = document.getElementById(`cell-${i}`);
          cell.innerText = "";
          cell.style.backgroundColor = "#555";
          cell.style.opacity = "1";
        }
        document.getElementById("turnIndicator").innerText =
          "Menunggu Giliran...";
        showPanel("panel-start");
      }

      function toggleFullScreen() {
        if (
          !document.fullscreenElement &&
          !document.mozFullScreenElement &&
          !document.webkitFullscreenElement &&
          !document.msFullscreenElement
        ) {
          if (document.documentElement.requestFullscreen) {
            document.documentElement.requestFullscreen();
          } else if (document.documentElement.msRequestFullscreen) {
            document.documentElement.msRequestFullscreen();
          } else if (document.documentElement.mozRequestFullScreen) {
            document.documentElement.mozRequestFullScreen();
          } else if (document.documentElement.webkitRequestFullscreen) {
            document.documentElement.webkitRequestFullscreen(
              Element.ALLOW_KEYBOARD_INPUT,
            );
          }
        } else {
          if (document.exitFullscreen) {
            document.exitFullscreen();
          } else if (document.msExitFullscreen) {
            document.msExitFullscreen();
          } else if (document.mozCancelFullScreen) {
            document.mozCancelFullScreen();
          } else if (document.webkitExitFullscreen) {
            document.webkitExitFullscreen();
          }
        }
      }
    </script>
  </body>
</html>
